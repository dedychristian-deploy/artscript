sub OnInitParameters()
	
	RegisterParameterString("_windowspath", "Windows Path", "\\\\192.168.16.160\\website$\\socialnetwork\\", 60,100, "")
	RegisterParameterString("AllSOCMED", "Data Social Media", "wide_shot_socialnetwork.txt", 40,100, "")

end sub

	
sub GetAllSOCMED()

aa.clear
aa.push(" ")
bb.clear
bb.push(" ")
	dim i as integer

		'tentukan lokasi file text
		fileAllSOCMED = GetParameterString("_windowspath") & GetParameterString("AllSOCMED")

		'ambil isi file text
		System.LoadTextFile(fileAllSOCMED, strDataAllSOCMED)

		strDataAllSOCMED.split(Chr(10), arrRowAllSOCMED)

				for i = 0 to arrRowAllSOCMED.ubound
				
				arrRowAllSOCMED[i].split(".",strRowAllSOCMED)
			 
				sosmedlist.Join(aa,"")
				'sosmedlist1.Join(bb," ")

				'cek jika ini adalah twitter
				
				if strRowAllSOCMED[0] = "[F]" then
				
				strRowAllSOCMED[1] = ""
				strRowAllSOCMED[2] = ""
				'strRowAllSOCMED[1].erase(0,1)
				'strRowAllSOCMED[2].erase(0,1)
				
				end if
				'scene.findcontainer("KOMENTAR_TWITTER").Geometry.text =   sosmedlist
				'scene.findcontainer("KOMENTAR_TWITTER2").Geometry.text =  sosmedlist	
				
				if strRowAllSOCMED[1] = "" and strRowAllSOCMED[2] = "" then
				'scene.findcontainer("KOMENTAR_TWITTER2").Geometry.text =  ""
				
				aa.push(strRowAllSOCMED[1] & strRowAllSOCMED[2] & " "  )
				
				else
				
				scene.findcontainer("KOMENTAR_TWITTER").Geometry.text =   sosmedlist
				scene.findcontainer("KOMENTAR_TWITTER2").Geometry.text =  sosmedlist
				
				aa.push(strRowAllSOCMED[1] & strRowAllSOCMED[2] & " "  )
				
				end if
				
 
				next
				
				'ini array baru
				println "array twitter " & sosmedlist
				
				'println "array FB " & sosmedlist1
				
				for i = 0 to arrRowAllSOCMED.ubound
								
				arrRowAllSOCMED[i].split(".",strRowAllSOCMED)
								
				'sosmedlist.Join(aa," ")
				sosmedlist1.Join(bb,"")
				'cek jika ini adalah twitter
				
				if strRowAllSOCMED[0] = "[T]" then
				

				strRowAllSOCMED[1]  = ""
				strRowAllSOCMED[2] = ""
				
				end if
				
				bb.push(strRowAllSOCMED[1] & strRowAllSOCMED[2] & " " )
				'scene.findcontainer("KOMENTAR_FACEBOOK").Geometry.text =   sosmedlist 
				
				next
				
				'ini array baru
				println "array FB " & sosmedlist1
				
				if sosmedlist1 = "" then
				scene.findcontainer("KOMENTAR_TWITTER").Geometry.text =   sosmedlist
				scene.findcontainer("KOMENTAR_TWITTER2").Geometry.text =  ""
				scene.findcontainer("KOMENTAR_FACEBOOK").Geometry.text =   sosmedlist1
				else
				scene.findcontainer("KOMENTAR_TWITTER").Geometry.text =   sosmedlist
				scene.findcontainer("KOMENTAR_TWITTER2").Geometry.text =  sosmedlist
				scene.findcontainer("KOMENTAR_FACEBOOK").Geometry.text =   "" 
				end if
				
	
end sub

						
sub jalan()

