sub reset()

	scene.findcontainer("KOMENTAR_TWITTER").Position.x = 262
	scene.findcontainer("KOMENTAR_TWITTER2").Position.x = 262

end sub

sub p_start()
	komentar1 = true
end sub

sub p_pause()
	komentar1 = false
end sub

sub p_reset( ab_val as boolean)
	
	ib_reset = ab_val
	if ib_reset then
		ib_reset = false
		ib_start = false
		
		scene.findcontainer("KOMENTAR_TWITTER").Position.x = 262
	end if
end sub

sub p_reset2( ab_val as boolean)
	
	ib_reset = ab_val
	if ib_reset then
		ib_reset = false
		ib_start = false
		
		scene.findcontainer("KOMENTAR_TWITTER2").Position.x = 262
	end if
end sub


