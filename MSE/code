    public partial class Form1 : Form
    {
        private static readonly HttpClient client = new HttpClient();

        private string url_take = "";
        private string url_update = "";
        private string url_activation = "";
        private string url_data_element = "";
        public Form1()
        {
            InitializeComponent();
